{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "platforms": ["macOS", "windows", "linux"],
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:window:allow-hide",
    "opener:default",
    "os:default",
    "shell:default",
    "store:default",
    "autostart:default",
    "fs:default",
    "dialog:default",
    {
      "identifier": "fs:scope",
      "allow": ["$CACHE/**"]
    },
    {
      "identifier": "fs:allow-remove",
      "allow": ["$CACHE/**"]
    },
    {
      "identifier": "shell:allow-execute",
      "allow": [
        {
          "name": "binaries/ffmpeg",
          "sidecar": true,
          "args": true
        }
      ]
    }
  ]
}
