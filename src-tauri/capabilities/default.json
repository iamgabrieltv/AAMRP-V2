{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "opener:default",
    "os:default",
    "shell:default",
    {
      "identifier": "shell:allow-execute",
      "allow": [
        {
          "name": "osascript",
          "cmd": "/usr/bin/osascript",
          "args": [{ "validator": ".+\\.scpt$" }]
        }
      ]
    }
  ]
}
