{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "AAMRP",
  "version": "0.1.0",
  "identifier": "dev.iamgabriel.aamrp-v2",
  "build": {
    "beforeDevCommand": "bun run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "bun run build",
    "frontendDist": "../build"
  },
  "app": {
    "windows": [
      {
        "title": "AAMRP",
        "width": 250,
        "height": 300
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": ["resources/mac.scpt", "icons/TrayIcon-Template.png"],
    "externalBin": ["binaries/ffmpeg"]
  }
}
